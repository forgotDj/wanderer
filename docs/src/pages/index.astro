---
import { Image } from "astro:assets";
import featuresImg from "../assets/hero.png";
import PageNav from "../components/page_nav.astro";
import PageFooter from "../components/page_footer.astro";

import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/600.css";
import "@fontsource/ibm-plex-sans/700.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/600.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>wanderer — Your trails. Your data. Your server.</title>
    <meta
      name="description"
      content="The open-source, self-hosted trail catalogue. Organize, plan, and share GPS tracks without the algorithm, the paywall, or the subscription."
    />
    <link rel="icon" href="/favicon.svg" />
  </head>

  <body>
    <!-- ─── NAV ──────────────────────────────────────────────────────────── -->
    <PageNav />

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <section class="hero">
      <canvas id="hero-topo" aria-hidden="true"></canvas>
      <div class="hero-content">
        <div class="hero-badge">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            ><path
              d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"
            ></path></svg
          >
          Open source · AGPLv3 · Self-hosted
        </div>

        <h1
          class="hero-headline"
          aria-label="Your trails. Your data. Your server."
        >
          <span class="hero-line">Your trails.</span>
          <span class="hero-line hero-line--dim">Your data.</span>
          <span class="hero-line hero-line--dimmer">Your server.</span>
        </h1>

        <p class="hero-sub">
          The open-source trail catalogue: organize, plan, and share GPS tracks
          without any paywall or subscription.
        </p>

        <div class="hero-ctas">
          <a href="/run/installation/quick" class="cta-primary">
            Quick Start
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </a>
          <a
            href="https://demo.wanderer.to"
            class="cta-secondary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Try the Demo
          </a>
        </div>
      </div>

      <div class="hero-screenshot" aria-hidden="true">
        <div class="hero-screenshot-frame">
          <video
            class="hero-img"
            poster="/favicon.svg"
            autoplay
            muted
            loop
            playsinline
          >
            <source src="/wanderer_trailer.webm" type="video/webm" />
            <source src="/wanderer_trailer.mp4" type="video/mp4" />

            Your browser does not support the video tag.
          </video>
        </div>
      </div>
    </section>

    <!-- ─── PATHS ────────────────────────────────────────────────────────── -->
    <section class="paths" aria-label="How to get started">
      <div class="path path--self-host reveal">
        <div class="path-eyebrow">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="3" width="20" height="14" rx="2"></rect><path
              d="M8 21h8M12 17v4"></path>
          </svg>
          Self-host
        </div>
        <h2 class="path-heading">Run your own instance.</h2>
        <p class="path-body">
          Your data, your rules, your server. Download the compose file and
          start it. Wanderer is up in under 90 seconds.
        </p>
        <div
          class="code-block"
          role="region"
          aria-label="Installation commands"
        >
          <div class="code-block-header">
            <span class="code-lang">bash</span>
            <span class="code-comment"># download &amp; launch</span>
          </div>
          <pre
            class="code-pre"><code class="code-content"><span class="code-comment-line"># Download the compose file</span>
<span class="code-cmd">wget</span> https://raw.githubusercontent.com/open-wanderer/wanderer/main/docker-compose.yml

<span class="code-comment-line"># Start wanderer</span>
<span class="code-cmd">docker</span> compose up -d</code></pre>
        </div>
        <div class="path-actions">
          <a href="/run/installation/quick" class="cta-primary">
            Full installation guide
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </a>
          <a href="/run/environment-configuration" class="cta-secondary">
            Environment config
          </a>
        </div>
      </div>

      <div class="path-divider" aria-hidden="true"><span>or</span></div>

      <a href="/servers" class="path path--join reveal">
        <div class="path-eyebrow">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle><path d="M12 8v4l3 3"
            ></path>
          </svg>
          Join a server
        </div>
        <h2 class="path-heading">Find a community to join.</h2>
        <p class="path-body">
          Don't want to manage infrastructure? Join an existing wanderer
          instance run by someone you trust.
        </p>
        <ol class="path-steps" aria-label="How to join a wanderer server">
          <li class="path-step">
            <span class="path-step-num" aria-hidden="true">1</span>
            <div class="path-step-body">
              <strong>Find someone running wanderer</strong>
              <span
                >A friend, hiking club, or outdoor organization who self-hosts
                an instance.</span
              >
            </div>
          </li>
          <li class="path-step">
            <span class="path-step-num" aria-hidden="true">2</span>
            <div class="path-step-body">
              <strong>Request an account</strong>
              <span>Register on their instance.</span>
            </div>
          </li>
          <li class="path-step">
            <span class="path-step-num" aria-hidden="true">3</span>
            <div class="path-step-body">
              <strong>Connect across instances</strong>
              <span
                >Follow trails and explorers on other servers via ActivityPub
                federation.</span
              >
            </div>
          </li>
        </ol>
        <span class="path-cta">
          Browse servers
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
        </span>
      </a>
    </section>

    <!-- ─── PILLARS ──────────────────────────────────────────────────────── -->
    <section class="pillars" aria-label="Why wanderer">
      <div class="section-container">
        <div class="pillar reveal">
          <div class="pillar-marker" aria-hidden="true">01</div>
          <div class="pillar-body">
            <h2 class="pillar-heading">Own your data.</h2>
            <p class="pillar-text">
              Your GPS tracks live on your server, in your database, under your
              control. No vendor lock-in, no terms-of-service changes, no sudden
              sunset. Export any time in open formats.
            </p>
          </div>
        </div>

        <div class="pillar-rule" aria-hidden="true"></div>

        <div class="pillar reveal">
          <div class="pillar-marker" aria-hidden="true">02</div>
          <div class="pillar-body">
            <h2 class="pillar-heading">Every feature. Always free.</h2>
            <p class="pillar-text">
              Search, plan, share, map layers, summit logs, statistics, lists:
              no tier, no paywall, no annual plan required. Install it and use
              everything.
            </p>
          </div>
        </div>

        <div class="pillar-rule" aria-hidden="true"></div>

        <div class="pillar reveal">
          <div class="pillar-marker" aria-hidden="true">03</div>
          <div class="pillar-body">
            <h2 class="pillar-heading">Built on the open web.</h2>
            <p class="pillar-text">
              ActivityPub federation means your wanderer instance can share
              trails with other instances. Follow explorers across servers — no
              account needed on theirs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── FEATURES ────────────────────────────────────────────────────── -->
    <section class="features" aria-label="Features">
      <div class="section-container">
        <div class="features-grid">
          <div class="features-text reveal">
            <h2 class="section-heading">
              Everything you need to manage your trail data.
            </h2>
            <p class="section-body">
              From a post-hike GPX upload to a multi-week expedition plan,
              wanderer gives you the full toolkit — without the commercial
              baggage.
            </p>
            <ul class="feature-list" aria-label="Feature list">
              <li class="feature-item">
                <svg
                  class="feature-icon"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><polyline points="9 11 12 14 22 4"></polyline><path
                    d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                  ></path></svg
                >
                <span>Upload GPX, KML, FIT and more</span>
              </li>
              <li class="feature-item">
                <svg
                  class="feature-icon"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><polyline points="9 11 12 14 22 4"></polyline><path
                    d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                  ></path></svg
                >
                <span>Full-text and map-based search</span>
              </li>
              <li class="feature-item">
                <svg
                  class="feature-icon"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><polyline points="9 11 12 14 22 4"></polyline><path
                    d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                  ></path></svg
                >
                <span>Route planning with Valhalla routing</span>
              </li>
              <li class="feature-item">
                <svg
                  class="feature-icon"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><polyline points="9 11 12 14 22 4"></polyline><path
                    d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                  ></path></svg
                >
                <span>Elevation profiles and statistics</span>
              </li>
              <li class="feature-item">
                <svg
                  class="feature-icon"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><polyline points="9 11 12 14 22 4"></polyline><path
                    d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                  ></path></svg
                >
                <span>Lists, summit logs, and tags</span>
              </li>
              <li class="feature-item">
                <svg
                  class="feature-icon"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><polyline points="9 11 12 14 22 4"></polyline><path
                    d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                  ></path></svg
                >
                <span>Photo galleries and waypoints</span>
              </li>
              <li class="feature-item">
                <svg
                  class="feature-icon"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><polyline points="9 11 12 14 22 4"></polyline><path
                    d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                  ></path></svg
                >
                <span>Mobile app for iOS and Android</span>
              </li>
              <li class="feature-item">
                <svg
                  class="feature-icon"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><polyline points="9 11 12 14 22 4"></polyline><path
                    d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                  ></path></svg
                >
                <span>Plugin system for extensibility</span>
              </li>
            </ul>
            <a href="/use/create-a-trail" class="text-link">
              Explore all features
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
              >
            </a>
          </div>

          <div class="features-screenshot reveal">
            <Image
              src={featuresImg}
              alt="wanderer features overview showing trail cards and map interface"
              width={900}
              quality={80}
              loading="lazy"
              class="features-img"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ─── FEDERATION ──────────────────────────────────────────────────── -->
    <section class="federation" aria-label="ActivityPub federation">
      <div class="section-container">
        <div class="federation-layout">
          <div class="federation-text reveal">
            <div class="fed-tag" aria-hidden="true">ActivityPub</div>
            <h2 class="section-heading federation-heading">
              The social layer<br />for outdoor explorers.
            </h2>
            <p class="section-body">
              wanderer is built on ActivityPub — the same open standard that
              powers Mastodon and Pixelfed. Follow explorers on other instances
              and their public trails, comments, and summit logs appear in your
              feed — no account on their server required.
            </p>
            <p class="section-body">
              No walled gardens. No platform permission. Your data stays on your
              server; the social layer spans all of them.
            </p>
            <div class="fed-links">
              <a href="/develop/federation" class="text-link">
                Federation docs
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><path d="M5 12h14M12 5l7 7-7 7"></path></svg
                >
              </a>
              <a href="/servers" class="text-link">
                Discover instances
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><path d="M5 12h14M12 5l7 7-7 7"></path></svg
                >
              </a>
            </div>
          </div>

          <div class="federation-visual reveal" aria-hidden="true">
            <svg
              class="fed-diagram"
              viewBox="0 0 580 205"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <defs>
                <!--
                  Mountain paths from logo_dark.svg (512×512).
                  viewBox crops to the three triangle peaks (x96–416, y155–311).
                -->
                <symbol id="wdr-mountains" viewBox="96 155 320 156">
                  <path
                    d="M348.212 206.014C349.872 203.329 354.021 203.329 355.681 206.014L416.362 304.207C418.022 306.893 415.947 310.25 412.628 310.25H291.265C287.945 310.25 285.871 306.893 287.531 304.207L348.212 206.014Z"
                    fill="white"
                    opacity="0.5"></path>
                  <path
                    d="M164.723 183.276C166.612 180.005 171.334 180.005 173.223 183.276L242.282 302.889C244.17 306.161 241.809 310.25 238.032 310.25H99.9145C96.137 310.25 93.776 306.161 95.6648 302.889L164.723 183.276Z"
                    fill="white"
                    opacity="0.5"></path>
                  <path
                    d="M266.25 155C268.56 151 274.333 151 276.643 155L361.08 301.25C363.389 305.25 360.503 310.25 355.884 310.25H187.009C182.39 310.25 179.503 305.25 181.813 301.25L266.25 155Z"
                    fill="white"></path>
                </symbol>
                <clipPath id="flow-clip">
                  <rect x="130" y="0" width="320" height="205"></rect>
                </clipPath>
              </defs>

              <!-- ── Instance A ── -->
              <rect
                x="5"
                y="10"
                width="120"
                height="150"
                rx="8"
                fill="#1e2028"
                stroke="#374151"
                stroke-width="1"></rect>
              <use href="#wdr-mountains" x="17" y="38" width="96" height="47"
              ></use>
              <text
                x="65"
                y="118"
                text-anchor="middle"
                fill="#94a3b8"
                font-family="IBM Plex Mono, monospace"
                font-size="9.5">wanderer</text
              >
              <text
                x="65"
                y="148"
                text-anchor="middle"
                fill="#ffffff"
                font-family="IBM Plex Mono, monospace"
                font-size="10.5"
                font-weight="600">instance A</text
              >

              <!-- ── Instance B ── -->
              <rect
                x="455"
                y="10"
                width="120"
                height="150"
                rx="8"
                fill="#1e2028"
                stroke="#374151"
                stroke-width="1"></rect>
              <use href="#wdr-mountains" x="467" y="38" width="96" height="47"
              ></use>
              <text
                x="515"
                y="118"
                text-anchor="middle"
                fill="#94a3b8"
                font-family="IBM Plex Mono, monospace"
                font-size="9.5">wanderer</text
              >
              <text
                x="515"
                y="148"
                text-anchor="middle"
                fill="#ffffff"
                font-family="IBM Plex Mono, monospace"
                font-size="10.5"
                font-weight="600">instance B</text
              >

              <!-- ── Channel 1: A → B at y=72 ── -->
              <line
                x1="130"
                y1="72"
                x2="455"
                y2="72"
                stroke="#374151"
                stroke-width="1.5"></line>
              <path
                d="M449 67 L455 72 L449 77"
                stroke="#374151"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>

              <!-- ── Channel 2: B → A at y=108 ── -->
              <line
                x1="130"
                y1="108"
                x2="455"
                y2="108"
                stroke="#374151"
                stroke-width="1.5"></line>
              <path
                d="M136 103 L130 108 L136 113"
                stroke="#374151"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>

              <!-- ── Content type pills (between channels, y=84–102) ── -->
              <rect
                x="153"
                y="81"
                width="46"
                height="18"
                rx="4"
                fill="#242734"
                stroke="#374151"
                stroke-width="1"></rect>
              <text
                x="176"
                y="94"
                text-anchor="middle"
                fill="#ffffff"
                font-family="IBM Plex Sans, sans-serif"
                font-size="9.5"
                font-weight="500">trails</text
              >

              <rect
                x="271"
                y="81"
                width="38"
                height="18"
                rx="4"
                fill="#242734"
                stroke="#374151"
                stroke-width="1"></rect>
              <text
                x="290"
                y="94"
                text-anchor="middle"
                fill="#ffffff"
                font-family="IBM Plex Sans, sans-serif"
                font-size="9.5"
                font-weight="500">lists</text
              >

              <rect
                x="371"
                y="81"
                width="62"
                height="18"
                rx="4"
                fill="#242734"
                stroke="#374151"
                stroke-width="1"></rect>
              <text
                x="402"
                y="94"
                text-anchor="middle"
                fill="#ffffff"
                font-family="IBM Plex Sans, sans-serif"
                font-size="9.5"
                font-weight="500">comments</text
              >

              <!-- ── Dots on channel 1 (A → B), 3 staggered ── -->
              <g clip-path="url(#flow-clip)">
                <circle r="4" fill="#ffffff">
                  <animateMotion
                    dur="3s"
                    repeatCount="indefinite"
                    path="M130,72 L455,72"></animateMotion>
                </circle>
                <circle r="4" fill="#ffffff" opacity="0.6">
                  <animateMotion
                    dur="3s"
                    begin="1s"
                    repeatCount="indefinite"
                    path="M130,72 L455,72"></animateMotion>
                </circle>
                <circle r="4" fill="#ffffff" opacity="0.3">
                  <animateMotion
                    dur="3s"
                    begin="2s"
                    repeatCount="indefinite"
                    path="M130,72 L455,72"></animateMotion>
                </circle>

                <!-- ── Dots on channel 2 (B → A), 3 staggered ── -->
                <circle r="4" fill="#94a3b8">
                  <animateMotion
                    dur="3s"
                    repeatCount="indefinite"
                    path="M455,108 L130,108"></animateMotion>
                </circle>
                <circle r="4" fill="#94a3b8" opacity="0.6">
                  <animateMotion
                    dur="3s"
                    begin="1s"
                    repeatCount="indefinite"
                    path="M455,108 L130,108"></animateMotion>
                </circle>
                <circle r="4" fill="#94a3b8" opacity="0.3">
                  <animateMotion
                    dur="3s"
                    begin="2s"
                    repeatCount="indefinite"
                    path="M455,108 L130,108"></animateMotion>
                </circle>
              </g>

              <!-- ── Protocol label ── -->
              <text
                x="292"
                y="185"
                text-anchor="middle"
                fill="#94a3b8"
                font-family="IBM Plex Mono, monospace"
                font-size="9.5"
                letter-spacing="0.08em">ACTIVITYPUB</text
              >
            </svg>

            <div class="fed-caption">
              Follow an explorer on any instance — their public trails appear in
              your feed.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SUPPORT ──────────────────────────────────────────────────────── -->
