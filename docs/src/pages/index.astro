    function valueNoise(x: number, y: number): number {
      const xi = Math.floor(x),
        yi = Math.floor(y);
      const xf = x - xi,
        yf = y - yi;
      const u = smoothstep(xf),
        v = smoothstep(yf);
      const a = hash(xi, yi),
        b = hash(xi + 1, yi);
      const c = hash(xi, yi + 1),
        d = hash(xi + 1, yi + 1);
