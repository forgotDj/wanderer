<style>
  /* ── Reset & Base ───────────────────────────────────────────────────────── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }

  body {
    font-family:
      "IBM Plex Sans",
      -apple-system,
      BlinkMacSystemFont,
      sans-serif;
    background: #12141c;
    color: #ffffff;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: clip;
  }

  a {
    color: inherit;
  }
  img,
  video {
    display: block;
    max-width: 100%;
  }

  /* ── Tokens ─────────────────────────────────────────────────────────────── */
  :root {
    --polar-night: #242734;
    --deep-void: #12141c;
    --surface-dark: #1e2028;
    --carbon: #262831;
    --dusk-divide: #374151;
    --summit-fog: #94a3b8;
    --white: #ffffff;
    --signal-red: #ef4444;

    --container: min(1160px, 100% - 3rem);
    --section-py: clamp(4rem, 8vw, 7rem);
  }

  /* ── Section Container ──────────────────────────────────────────────────── */
  .section-container {
    width: var(--container);
    margin-inline: auto;
  }

  /* ── Typography Helpers ─────────────────────────────────────────────────── */
  .section-heading {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    text-wrap: balance;
    margin-bottom: 1rem;
  }

  .section-body {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--summit-fog);
    max-width: 56ch;
    margin-bottom: 1rem;
  }

  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--white);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    padding-bottom: 1px;
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .text-link:hover {
    border-color: var(--white);
