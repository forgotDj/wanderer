    }

    const LEVELS = 24;
    const NOISE_SCALE = 0.0028;
    const AMPLITUDE = 0.095;

    function resize(): void {
      const hero = canvas.closest(".hero");
      if (!(hero instanceof HTMLElement)) return;
      w = canvas.width = hero.offsetWidth;
      h = canvas.height = hero.offsetHeight;
    }

    function drawFrame(): void {
      if (!w || !h) return;
      ctx.clearRect(0, 0, w, h);

      mouseX += (targetMouseX - mouseX) * 0.04;

      for (let i = 0; i < LEVELS; i++) {
        const progress = i / (LEVELS - 1);
        const baseY = h * (0.05 + 0.92 * progress);
        const parallax = (mouseX - 0.5) * w * 0.03 * (0.2 + progress * 0.8);
        const opacity = 0.018 + progress * 0.062;
        const lineW = 0.3 + progress * 0.8;

        ctx.beginPath();
        ctx.strokeStyle = `rgba(255,255,255,${opacity.toFixed(3)})`;
        ctx.lineWidth = lineW;

        const steps = Math.ceil(w / 2.5);
        for (let j = 0; j <= steps; j++) {
          const x = (j / steps) * w;
          const nx = (x + parallax) * NOISE_SCALE + t * 0.07;
          const ny = baseY * NOISE_SCALE * 0.55 + i * 0.18;
          const nv = fbm(nx, ny);
          const y = baseY + nv * h * AMPLITUDE;
          j === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.stroke();
      }
    }

    function tick(): void {
      t += 0.003;
      drawFrame();
      rafId = requestAnimationFrame(tick);
    }

    function pause(): void {
      if (rafId !== null) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
    }

    function resume(): void {
      if (!reducedMotion && rafId === null) tick();
    }

    // Keep canvas matched to hero dimensions
    if (typeof ResizeObserver !== "undefined") {
      const ro = new ResizeObserver(resize);
      const hero = canvas.closest(".hero");
      if (hero) ro.observe(hero);
    } else {
      window.addEventListener("resize", resize, { passive: true });
    }

    // Pause rendering when hero scrolls out of view
    if (typeof IntersectionObserver !== "undefined") {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => (e.isIntersecting ? resume() : pause()));
        },
        { threshold: 0 },
      );
      io.observe(canvas);
    }

    document.addEventListener(
      "mousemove",
      (e: MouseEvent) => {
        targetMouseX = e.clientX / window.innerWidth;
      },
      { passive: true },
    );

    resize();

    if (reducedMotion) {
      drawFrame();
    } else {
      tick();
    }
  })();
</script>
